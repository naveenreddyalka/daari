<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.daari.serve</string>
    <key>ProgramArguments</key>
    <array>
        <string>__REPO__/.venv/bin/daari</string>
        <string>serve</string>
    </array>
    <key>WorkingDirectory</key>
    <string>__REPO__</string>
    <key>KeepAlive</key>
    <true/>
    <key>RunAtLoad</key>
    <true/>
    <key>StandardOutPath</key>
    <string>__HOME__/.daari/autodev/serve.out.log</string>
    <key>StandardErrorPath</key>
    <string>__HOME__/.daari/autodev/serve.err.log</string>
</dict>
</plist>
