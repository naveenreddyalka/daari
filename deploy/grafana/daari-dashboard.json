{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Requests by tier",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum by (tier) (rate(daari_requests_total[5m]))",
          "legendFormat": "{{tier}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Cache hit rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(daari_cache_hits_total[5m])) / clamp_min(sum(rate(daari_requests_total[5m])), 1e-9)",
          "legendFormat": "hit rate",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Latency p50 / p95 (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, tier) (rate(daari_request_latency_ms_bucket[5m])))",
          "legendFormat": "p50 {{tier}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, tier) (rate(daari_request_latency_ms_bucket[5m])))",
          "legendFormat": "p95 {{tier}}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 4,
      "title": "Escalations & errors",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "rate(daari_escalations_total[5m])",
          "legendFormat": "escalations",
          "refId": "A"
        },
        {
          "expr": "rate(daari_errors_total[5m])",
          "legendFormat": "errors",
          "refId": "B"
        }
      ]
    },
    {
      "id": 5,
      "title": "Frontier spend vs budget (USD)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "daari_frontier_spend_usd{window=\"daily\"}",
          "legendFormat": "daily spend",
          "refId": "A"
        },
        {
          "expr": "daari_frontier_budget_usd{window=\"daily\"}",
          "legendFormat": "daily budget",
          "refId": "B"
        },
        {
          "expr": "daari_frontier_spend_usd{window=\"monthly\"}",
          "legendFormat": "monthly spend",
          "refId": "C"
        }
      ]
    },
    {
      "id": 6,
      "title": "Cache false-hit rate (shadow sample)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "daari_cache_false_hit_rate",
          "legendFormat": "false-hit",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Budget state",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 16 },
      "targets": [
        {
          "expr": "daari_frontier_budget_state",
          "legendFormat": "{{state}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "Guardrail trips",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "sum by (action) (rate(daari_guardrail_trips_total[5m]))",
          "legendFormat": "{{action}}",
          "refId": "A"
        }
      ]
    }
  ],
