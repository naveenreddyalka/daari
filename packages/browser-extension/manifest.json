{
  "manifest_version": 3,
  "name": "daari prompt bridge",
  "version": "0.1.0",
  "description": "Send quick prompts to local daari (localhost:11435).",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "http://127.0.0.1:11435/*",
    "http://localhost:11435/*"
  ],
  "action": {
    "default_title": "daari",
    "default_popup": "popup.html"
  }
}
